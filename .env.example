# SECURITY
DEBUG=true
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# DATABASE (PostgreSQL via DATABASE_URL)
# Example:
# DATABASE_URL=postgres://username:password@localhost:5432/quizlet_db
DATABASE_URL=postgres://user:password@localhost:5432/quizlet_db

# CORS (for Flutter client, adjust later)
CORS_ALLOW_ALL_ORIGINS=true

